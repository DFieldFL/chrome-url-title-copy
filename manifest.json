{
  "manifest_version": 3,
  "name": "URL & Title Copier",
  "version": "1.0.0",
  "description": "Copy the current page title and URL as plain text, Markdown, or HTML via shortcuts or right click. Includes Rich based pasting.",
  "permissions": ["clipboardWrite", "activeTab", "storage", "scripting"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": { "service_worker": "background.js" },
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "commands": {
    "copy-plain": {
      "suggested_key": { "default": "Alt+Shift+C", "mac": "MacCtrl+Shift+C" },
      "description": "Copy page title and URL as plain text"
    },
    "copy-markdown": {
      "suggested_key": { "default": "Alt+Shift+M", "mac": "MacCtrl+Shift+M" },
      "description": "Copy page title and URL as Markdown link"
    },
    "copy-html": {
      "suggested_key": { "default": "Alt+Shift+H", "mac": "MacCtrl+Shift+H" },
      "description": "Copy page title and URL as HTML anchor tag"
    }
  }
}
